// Add styles to page
if (!document.getElementById('darkModeStyles')) {
    document.head.insertAdjacentHTML('beforeend', darkModeStyles);
}

// Function to set theme
function setTheme(theme) {
    const isDark = theme === 'dark';
    
    // Toggle body class
    if (isDark) {
        document.body.classList.add('dark-mode');
    } else {
        document.body.classList.remove('dark-mode');
    }
    
    // Update button active states
    if (darkBtn && lightBtn) {
        if (isDark) {
            darkBtn.classList.add('active');
            lightBtn.classList.remove('active');
        } else {
            lightBtn.classList.add('active');
            darkBtn.classList.remove('active');
        }
    }
    
    // Update toggle class if exists
    if (toggle) {
        if (isDark) {
            toggle.classList.add('dark-active');
        } else {
            toggle.classList.remove('dark-active');
        }
    }
    
    // Save to localStorage
    localStorage.setItem('theme', theme);
}

// Load saved theme
const savedTheme = localStorage.getItem('theme');
if (savedTheme === 'dark') {
    setTheme('dark');
} else {
    setTheme('light');
}

// Add event listeners if buttons exist
if (darkBtn) {
    darkBtn.addEventListener('click', () => setTheme('dark'));
}
if (lightBtn) {
    lightBtn.addEventListener('click', () => setTheme('light'));
}

// Optional: Detect system preference
if (!localStorage.getItem('theme')) {
    if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
        setTheme('dark');
    }
}

console.log('Dark mode initialized! 🌙✨');
