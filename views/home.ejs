<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate, private">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <title>SkyCast - Interactive Map Dashboard</title>
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#472dbb">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
     integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
     crossorigin=""/>
       <link 
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" 
    rel="stylesheet">
<!-- Search bar CSS (Leaflet Search) -->
<link rel="stylesheet" href="https://unpkg.com/leaflet-search/dist/leaflet-search.min.css" />
<!-- Geocoder CSS (Leaflet Control Geocoder) -->
<link rel="stylesheet" href="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.css" />

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="/context-menu.css">
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
     integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
     crossorigin=""></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            overflow: hidden;
        }

        /* Enhanced Header Section */
        .header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            background: rgba(218, 214, 214, 0.95);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.2);
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 5px 25px rgba(0, 0, 0, 0.1);
            gap: 20px;
        }

        .logo-section {
            display: flex;
            align-items: center;
            gap: 15px;
            min-width: 200px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 24px;
            font-weight: 700;
            color: #472dbb;
        }

        .logo i {
            font-size: 28px;
        }

        .welcome-text {
            font-size: 14px;
            color: #666;
            font-weight: 500;
        }

        /* Search Section */
        .search-section {
            flex: 1;
            max-width: 500px;
            margin: 0 20px;
        }

        .search-container {
            position: relative;
            width: 100%;
        }

        .search-input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .search-icon {
            position: absolute;
            left: 15px;
            color: #999;
            font-size: 16px;
            z-index: 2;
        }

        .search-input {
            width: 100%;
            padding: 12px 15px 12px 45px;
            border: 2px solid #e1e5e9;
            border-radius: 25px;
            font-size: 14px;
            background: rgba(255, 255, 255, 0.9);
            transition: all 0.3s ease;
            outline: none;
        }

        .search-input:focus {
            border-color: #472dbb;
            background: white;
            box-shadow: 0 0 0 3px rgba(71, 45, 187, 0.1);
        }

        .search-results {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            background: white;
            border: 1px solid #e1e5e9;
            border-radius: 10px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            max-height: 300px;
            overflow-y: auto;
            z-index: 1000;
            display: none;
        }

        .search-result-item {
            padding: 12px 15px;
            cursor: pointer;
            border-bottom: 1px solid #f0f0f0;
            transition: background-color 0.2s ease;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .search-result-item:hover {
            background-color: #f8f9fa;
        }

        .search-result-item:last-child {
            border-bottom: none;
        }

        .search-result-icon {
            color: #472dbb;
            font-size: 16px;
            width: 20px;
            text-align: center;
        }

        .search-result-text {
            flex: 1;
        }

        .search-result-name {
            font-weight: 600;
            color: #333;
            font-size: 14px;
        }

        .search-result-type {
            color: #666;
            font-size: 12px;
            text-transform: capitalize;
        }

        /* User Section */
        .user-section {
            min-width: 200px;
            display: flex;
            justify-content: flex-end;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
            position: relative;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, #472dbb 0%, #6c5ce7 100%);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 16px;
        }

        .user-details {
            display: flex;
            flex-direction: column;
        }

        .user-name {
            font-weight: 600;
            color: #333;
            font-size: 14px;
        }

        .user-status {
            color: #2ed573;
            font-size: 12px;
            font-weight: 500;
        }

        .user-dropdown {
            position: relative;
        }

        .dropdown-toggle {
            background: none;
            border: none;
            color: #666;
            cursor: pointer;
            padding: 8px;
            border-radius: 50%;
            transition: all 0.3s ease;
        }

        .dropdown-toggle:hover {
            background: rgba(71, 45, 187, 0.1);
            color: #472dbb;
        }

        .dropdown-menu {
            position: absolute;
            top: 100%;
            right: 0;
            background: white;
            border: 1px solid #e1e5e9;
            border-radius: 10px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            min-width: 200px;
            z-index: 1000;
            display: none;
            overflow: hidden;
        }

        .dropdown-menu.show {
            display: block;
            animation: slideDown 0.3s ease;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .dropdown-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 15px;
            color: #333;
            text-decoration: none;
            transition: background-color 0.2s ease;
            font-size: 14px;
        }

        .dropdown-item:hover {
            background-color: #f8f9fa;
            color: #472dbb;
        }

        .dropdown-item.logout {
            color: #ff4757;
        }

        .dropdown-item.logout:hover {
            background-color: #fff5f5;
        }

        .dropdown-divider {
            margin: 5px 0;
            border: none;
            border-top: 1px solid #e1e5e9;
        }

        /* Auth Buttons */
        .auth-buttons {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 25px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #472dbb 0%, #6c5ce7 100%);
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(71, 45, 187, 0.3);
        }

        .btn-outline-primary {
            background: rgba(255, 255, 255, 0.9);
            color: #472dbb;
            border: 2px solid #472dbb;
        }

        .btn-outline-primary:hover {
            background: #472dbb;
            color: white;
            transform: translateY(-2px);
        }

        .logo-section {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 24px;
            font-weight: 700;
            color: #472dbb;
        }

        .logo i {
            font-size: 28px;
            background: linear-gradient(135deg, #472dbb, #6c5ce7);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .welcome-text {
            color: #666;
            font-size: 16px;
            font-weight: 500;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, #472dbb, #6c5ce7);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 600;
            font-size: 16px;
        }

        
        .user-actions {
            display: flex;
            gap: 15px;
        }

        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 25px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #472dbb, #6c5ce7);
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(71, 45, 187, 0.3);
        }

        .btn-secondary {
            background: rgba(255, 255, 255, 0.9);
            color: #472dbb;
            border: 2px solid #472dbb;
        }

        .btn-secondary:hover {
            background: #472dbb;
            color: white;
            transform: translateY(-2px);
        }

        /* Map Container */
        .map-container {
            position: relative;
            width: 100vw;
            height: 100vh;
            margin-top: 80px;
        }

        #map {
            width: 100%;
            height: 100%;
            border-radius: 0;
        }

        /* Enhanced Control Panel */
        .control-panel {
            position: fixed;
            top: 100px;
            left: 30px;
            z-index: 999;
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(20px);
            border-radius: 20px;
            padding: 25px;
            box-shadow: 
                0 20px 40px rgba(0, 0, 0, 0.1),
                0 8px 16px rgba(0, 0, 0, 0.05),
                inset 0 1px 0 rgba(255, 255, 255, 0.8);
            border: 1px solid rgba(255, 255, 255, 0.5);
            min-width: 280px;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            max-height: calc(100vh - 140px);
            overflow-y: auto;
            transform: translateX(-150%);
            opacity: 0;
            pointer-events: none;
        }

        .control-panel.show {
            transform: translateX(0);
            opacity: 1;
            pointer-events: auto;
        }

        /* Floating Map Controls Button */
        .controls-fab {
            position: fixed;
            left: 30px;
            top: 100px;
            z-index: 998;
            width: 56px;
            height: 56px;
            border-radius: 50%;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            background: linear-gradient(135deg, #472dbb 0%, #6c5ce7 100%);
            box-shadow: 0 10px 24px rgba(0,0,0,0.18);
            cursor: pointer;
            transition: transform .2s ease, box-shadow .2s ease, background 0.3s;
        }

        .controls-fab:hover {
            transform: translateY(-2px) scale(1.05);
            box-shadow: 0 14px 28px rgba(0,0,0,0.22);
            background: linear-gradient(135deg, #37229b 0%, #5b4cd7 100%);
        }

        .controls-fab.hidden {
            transform: scale(0) rotate(-90deg);
            opacity: 0;
            pointer-events: none;
        }

        .controls-fab i { font-size: 20px; }

        .control-panel:hover {
            transform: translateY(-2px);
            box-shadow: 
                0 25px 50px rgba(0, 0, 0, 0.15),
                0 12px 24px rgba(0, 0, 0, 0.1),
                inset 0 1px 0 rgba(255, 255, 255, 0.9);
        }

        .control-panel h3 {
            color: #333;
            margin-bottom: 20px;
            font-size: 20px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
            padding-bottom: 15px;
            border-bottom: 10px solid rgba(7, 7, 7, 0.1);
        }

        .control-panel h3 i {
            color: #472dbb;
            font-size: 18px;
        }

        .control-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 15px 18px;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            margin-bottom: 10px;
            background: rgba(255, 255, 255, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.3);
            position: relative;
            overflow: hidden;
        }

        .control-item::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 0;
            height: 100%;
            background: linear-gradient(135deg, #472dbb 0%, #6c5ce7 100%);
            transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: -1;
        }

        .control-item:hover {
            transform: translateX(8px) translateY(-2px);
            box-shadow: 0 8px 25px rgba(71, 45, 187, 0.2);
            border-color: rgba(71, 45, 187, 0.3);
        }

        .control-item:hover::before {
            width: 100%;
        }

        .control-item:hover i,
        .control-item:hover span {
            color: white;
        }

        .control-item:active {
            transform: translateX(4px) translateY(-1px) scale(0.98);
        }

        .control-item i {
            color: #472dbb;
            font-size: 18px;
            width: 24px;
            text-align: center;
            transition: all 0.3s ease;
            z-index: 1;
        }

        .control-item:hover i {
            transform: scale(1.1);
        }

        .control-item span {
            color: #333;
            font-weight: 600;
            font-size: 15px;
            transition: all 0.3s ease;
            z-index: 1;
        }

        /* Active/Selected State */
        .control-item.active {
            background: linear-gradient(135deg, #472dbb 0%, #6c5ce7 100%);
            color: white;
            box-shadow: 0 8px 25px rgba(71, 45, 187, 0.3);
        }

        .control-item.active i,
        .control-item.active span {
            color: white;
        }

        /* Loading State */
        .control-item.loading {
            pointer-events: none;
            opacity: 0.7;
        }

        .control-item.loading i {
            animation: pulse 1.5s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        /* Control Status Indicators */
        .control-status {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 12px;
            opacity: 0.8;
            transition: all 0.3s ease;
        }

        .control-item:hover .control-status {
            opacity: 1;
            transform: translateX(-2px);
        }

        /* Status indicators */
        .status-online {
            color: #2ed573;
        }

        .status-offline {
            color: #ff4757;
        }

        .status-loading {
            color: #ffa502;
        }

        /* Stats Panel */
        .stats-panel {
            position: fixed;
            bottom: 30px;
            right: 30px;
            z-index: 999;
            background: rgba(218, 214, 214, 0.95);
            backdrop-filter: blur(20px);
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            min-width: 200px;
        }

        .stats-panel h3 {
            color: #333;
            margin-bottom: 15px;
            font-size: 16px;
            font-weight: 600;
        }

        .stat-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 0;
            border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        }

        .stat-item:last-child {
            border-bottom: none;
        }

        .stat-label {
            color: #666;
            font-size: 14px;
        }

        .stat-value {
            color: #472dbb;
            font-weight: 600;
            font-size: 14px;
        }

        /* Loading Animation */
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.9);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            transition: opacity 0.5s ease;
        }

        .loading-spinner {
            width: 50px;
            height: 50px;
            border: 4px solid #f3f3f3;
            border-top: 4px solid #472dbb;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Responsive Design */
        @media (max-width: 768px) {
            .header {
                padding: 10px 15px;
                flex-direction: column;
                gap: 10px;
            }

            .control-panel {
                left: 15px;
                top: 120px;
                min-width: 200px;
            }

            .stats-panel {
                bottom: 15px;
                right: 15px;
                min-width: 150px;
            }

            .map-container {
                margin-top: 120px;
            }
        }

        /* Animation Classes */
        .fade-in {
            animation: fadeIn 0.5s ease-in;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .slide-in-left {
            animation: slideInLeft 0.5s ease-out;
        }

        @keyframes slideInLeft {
            from { opacity: 0; transform: translateX(-50px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .slide-in-right {
            animation: slideInRight 0.5s ease-out;
        }

        @keyframes slideInRight {
            from { opacity: 0; transform: translateX(50px); }
            to { opacity: 1; transform: translateX(0); }
        }

        @keyframes slideOutRight {
            from { opacity: 1; transform: translateX(0); }
            to { opacity: 0; transform: translateX(50px); }
        }

        /* Notification Styles */
        .notification {
            animation: slideInRight 0.3s ease;
        }

        .notification-content {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .notification-content i {
            font-size: 16px;
        }

        /* Ensure Leaflet controls (search / geocoder) are visible below the fixed header */
        .leaflet-control-container .leaflet-top {
            top: 80px !important; /* match header height */
        }

        .leaflet-control-geocoder,
        .leaflet-control-search {
            z-index: 1100 !important;
        }


        /* Enhanced Weather Modal Styles */
        .weather-modal {
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.15);
        }

        .weather-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            padding: 25px 30px;
            position: relative;
            overflow: hidden;
        }

        .weather-header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
            animation: weatherFloat 6s ease-in-out infinite;
        }

        @keyframes weatherFloat {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(180deg); }
        }

        .weather-header-content {
            display: flex;
            align-items: center;
            gap: 20px;
            position: relative;
            z-index: 2;
        }

        .weather-icon-large {
            font-size: 3rem;
            color: rgba(255, 255, 255, 0.9);
            animation: weatherPulse 2s ease-in-out infinite;
        }

        @keyframes weatherPulse {
            0%, 100% { transform: scale(1); opacity: 0.9; }
            50% { transform: scale(1.1); opacity: 1; }
        }

        .weather-title-section h4 {
            color: white;
            font-weight: 700;
            margin: 0;
            font-size: 1.8rem;
        }

        .weather-subtitle {
            color: rgba(255, 255, 255, 0.8);
            margin: 5px 0 0 0;
            font-size: 1rem;
        }

        .weather-body {
            padding: 30px;
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        }

        .weather-status-banner {
            background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
            color: white;
            padding: 15px 20px;
            border-radius: 12px;
            margin-bottom: 25px;
            box-shadow: 0 8px 25px rgba(23, 162, 184, 0.3);
        }

        .status-content {
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 600;
        }

        .weather-features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .weather-feature-card {
            background: white;
            border-radius: 15px;
            padding: 25px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
            border: 1px solid rgba(0, 0, 0, 0.05);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }

        .weather-feature-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }

        .weather-feature-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.15);
        }

        .weather-feature-card:hover::before {
            transform: scaleX(1);
        }

        .feature-icon {
            width: 60px;
            height: 60px;
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin-bottom: 15px;
            transition: all 0.3s ease;
        }

        .weather-feature-card[data-feature="temperature"] .feature-icon {
            background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
            color: white;
        }

        .weather-feature-card[data-feature="precipitation"] .feature-icon {
            background: linear-gradient(135deg, #74b9ff 0%, #0984e3 100%);
            color: white;
        }

        .weather-feature-card[data-feature="wind"] .feature-icon {
            background: linear-gradient(135deg, #a29bfe 0%, #6c5ce7 100%);
            color: white;
        }

        .weather-feature-card[data-feature="air-quality"] .feature-icon {
            background: linear-gradient(135deg, #00b894 0%, #00a085 100%);
            color: white;
        }

        .weather-feature-card:hover .feature-icon {
            transform: scale(1.1) rotate(5deg);
        }

        .feature-content h6 {
            color: #2d3436;
            font-weight: 700;
            margin-bottom: 8px;
            font-size: 1.1rem;
        }

        .feature-content p {
            color: #636e72;
            font-size: 0.9rem;
            margin-bottom: 15px;
            line-height: 1.4;
        }

        .feature-tags {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .tag {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .feature-action {
            position: absolute;
            top: 20px;
            right: 20px;
            color: #ddd;
            font-size: 1.2rem;
            transition: all 0.3s ease;
        }

        .weather-feature-card:hover .feature-action {
            color: #667eea;
            transform: translateX(5px);
        }

        .weather-feature-card.active {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            transform: translateY(-8px);
            box-shadow: 0 15px 40px rgba(102, 126, 234, 0.3);
        }

        .weather-feature-card.active .feature-content h6,
        .weather-feature-card.active .feature-content p {
            color: white;
        }

        .weather-feature-card.active .feature-action {
            color: white;
        }

        .weather-feature-card.active::before {
            background: rgba(255, 255, 255, 0.3);
            transform: scaleX(1);
        }

        .weather-visualization {
            background: white;
            border-radius: 15px;
            padding: 25px;
            margin-bottom: 25px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
        }

        .section-title {
            color: #2d3436;
            font-weight: 700;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1.2rem;
        }

        .section-title i {
            color: #667eea;
        }

        .visualization-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
        }

        .chart-container {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 20px;
            border: 1px solid #e9ecef;
        }

        .chart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .chart-header h6 {
            color: #2d3436;
            font-weight: 600;
            margin: 0;
        }

        .chart-controls {
            display: flex;
            gap: 8px;
        }

        .chart-controls .btn {
            border-radius: 20px;
            padding: 6px 12px;
            font-size: 0.8rem;
            transition: all 0.3s ease;
        }

        .chart-controls .btn.active {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-color: transparent;
            color: white;
        }

        .chart-canvas-wrap {
            position: relative;
            height: 220px;
            min-height: 220px;
        }

        .chart-canvas-wrap canvas {
            width: 100% !important;
            height: 100% !important;
        }

        .chart-placeholder {
            height: 220px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #636e72;
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            border-radius: 8px;
            border: 2px dashed #dee2e6;
        }

        .chart-placeholder.chart-error {
            border-color: #ff6b7a;
            color: #c0392b;
        }

        .chart-placeholder i {
            font-size: 2rem;
            margin-bottom: 10px;
            color: #adb5bd;
        }

        .weather-controls {
            background: white;
            border-radius: 15px;
            padding: 25px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
        }

        .controls-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 25px;
        }

        .control-group {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .control-label {
            color: #2d3436;
            font-weight: 600;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .date-range-picker {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .date-range-picker .form-control {
            border-radius: 8px;
            border: 2px solid #e9ecef;
            transition: all 0.3s ease;
        }

        .date-range-picker .form-control:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .date-separator {
            color: #636e72;
            font-weight: 600;
        }

        .checkbox-group {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
        }

        .form-check {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .form-check-input {
            width: 18px;
            height: 18px;
            border-radius: 4px;
        }

        .form-check-input:checked {
            background-color: #667eea;
            border-color: #667eea;
        }

        .form-check-label {
            color: #2d3436;
            font-weight: 500;
            cursor: pointer;
        }

        .weather-footer {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            border: none;
            padding: 20px 30px;
        }

        .footer-actions {
            display: flex;
            gap: 15px;
            justify-content: flex-end;
        }

        .footer-actions .btn {
            border-radius: 25px;
            padding: 10px 20px;
            font-weight: 600;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .footer-actions .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        }

        /* Enhanced Weather Modal Body Styles */
        .weather-header-info {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            padding: 20px;
            border-radius: 12px;
            margin-bottom: 20px;
            border: 1px solid #dee2e6;
        }

        .location-info, .date-range-info {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 10px;
        }

        .location-info:last-child, .date-range-info:last-child {
            margin-bottom: 0;
        }

        .location-text, .date-text {
            font-size: 1rem;
            color: #2d3436;
        }

        .weather-divider {
            border: none;
            height: 2px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            margin: 20px 0;
        }

        .section-title {
            color: #2d3436;
            font-weight: 700;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1.2rem;
        }

        .weather-day-card {
            background: white;
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 20px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
            border: 1px solid rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
        }

        .weather-day-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.12);
        }

        .day-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 1px solid #e9ecef;
        }

        .day-date {
            font-weight: 700;
            color: #2d3436;
            font-size: 1.1rem;
        }

        .day-status {
            display: flex;
            align-items: center;
            gap: 5px;
            color: #28a745;
            font-size: 0.9rem;
            font-weight: 600;
        }

        .weather-metrics-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
        }

        .metric-card {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 15px;
            text-align: center;
            transition: all 0.3s ease;
            border: 2px solid transparent;
        }

        .metric-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
        }

        .temperature-card:hover {
            border-color: #ff6b6b;
            background: linear-gradient(135deg, #fff5f5 0%, #ffe8e8 100%);
        }

        .precipitation-card:hover {
            border-color: #74b9ff;
            background: linear-gradient(135deg, #f0f8ff 0%, #e6f3ff 100%);
        }

        .wind-card:hover {
            border-color: #a29bfe;
            background: linear-gradient(135deg, #f8f6ff 0%, #f0edff 100%);
        }

        .air-quality-card:hover {
            border-color: #00b894;
            background: linear-gradient(135deg, #f0fff4 0%, #e8f8f0 100%);
        }

        .metric-header {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-bottom: 10px;
        }

        .metric-header i {
            font-size: 1.2rem;
        }

        .metric-label {
            font-weight: 600;
            color: #2d3436;
            font-size: 0.9rem;
        }

        .metric-value {
            font-size: 1.5rem;
            font-weight: 700;
            color: #2d3436;
            margin-bottom: 5px;
        }

        .metric-analysis {
            font-size: 0.8rem;
            color: #636e72;
            font-weight: 500;
        }

        .weather-summary {
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #e9ecef;
        }

        .summary-card {
            background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
            padding: 15px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            gap: 10px;
            color: #1565c0;
            font-weight: 600;
        }

        .summary-card i {
            font-size: 1.1rem;
        }

        /* Responsive adjustments */
        @media (max-width: 768px) {
            .weather-metrics-grid {
                grid-template-columns: 1fr;
            }
            
            .day-header {
                flex-direction: column;
                gap: 10px;
                text-align: center;
            }
        }

        /* AI Chatbot Styles */
        .chatbot-modal {
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.15);
        }

        .chatbot-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            padding: 20px 25px;
            position: relative;
            overflow: hidden;
        }

        .chatbot-header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
            animation: chatbotFloat 8s ease-in-out infinite;
        }

        @keyframes chatbotFloat {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-15px) rotate(180deg); }
        }

        .chatbot-title-section {
            display: flex;
            align-items: center;
            gap: 15px;
            position: relative;
            z-index: 2;
        }

        .chatbot-icon {
            width: 50px;
            height: 50px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: white;
            animation: chatbotPulse 2s ease-in-out infinite;
        }

        @keyframes chatbotPulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        .chatbot-info h5 {
            color: white;
            font-weight: 700;
            margin: 0;
            font-size: 1.4rem;
        }

        .chatbot-subtitle {
            color: rgba(255, 255, 255, 0.9);
            margin: 5px 0 0 0;
            font-size: 0.9rem;
        }

        .chatbot-body {
            padding: 0;
            background: #f8f9fa;
            height: 500px;
            display: flex;
            flex-direction: column;
        }

        .chat-messages {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
            background: white;
            border-bottom: 1px solid #e9ecef;
        }

        .chat-message {
            display: flex;
            margin-bottom: 15px;
            animation: messageSlide 0.3s ease-out;
        }

        @keyframes messageSlide {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .message-avatar {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 10px;
            flex-shrink: 0;
        }

        .bot-message .message-avatar {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .user-message .message-avatar {
            background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
            color: white;
        }

        .message-content {
            flex: 1;
            max-width: 80%;
        }

        .message-text {
            background: #f8f9fa;
            padding: 12px 16px;
            border-radius: 18px;
            font-size: 0.9rem;
            line-height: 1.4;
            color: #2d3436;
            white-space: normal;
        }

        .chat-message[dir="rtl"] .message-text {
            text-align: right;
            direction: rtl;
            font-family: 'Segoe UI', Tahoma, Arial, sans-serif;
        }

        .chat-message[dir="rtl"] .message-avatar {
            margin-right: 0;
            margin-left: 10px;
        }

        .user-message .message-text {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            margin-left: auto;
        }

        .message-time {
            font-size: 0.75rem;
            color: #636e72;
            margin-top: 5px;
            text-align: right;
        }

        .user-message .message-time {
            text-align: left;
        }

        .chat-input-area {
            padding: 20px;
            background: white;
            border-top: 1px solid #e9ecef;
        }

        .quick-questions {
            display: flex;
            gap: 8px;
            margin-bottom: 10px;
            flex-wrap: wrap;
            max-height: 140px;
            overflow-y: auto;
            padding-right: 4px;
        }

        .quick-prompts-label {
            font-size: 0.75rem;
            font-weight: 600;
            color: #636e72;
            margin: 8px 0 4px;
            width: 100%;
        }

        .quick-question-btn {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            border: 1px solid #dee2e6;
            border-radius: 20px;
            padding: 8px 12px;
            font-size: 0.8rem;
            color: #2d3436;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .quick-question-btn:hover {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
        }

        .chat-input-container {
            position: relative;
        }

        .input-wrapper {
            display: flex;
            align-items: center;
            background: #f8f9fa;
            border-radius: 25px;
            padding: 8px 15px;
            border: 2px solid #e9ecef;
            transition: all 0.3s ease;
        }

        .input-wrapper:focus-within {
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .chat-input {
            flex: 1;
            border: none;
            background: transparent;
            outline: none;
            font-size: 0.9rem;
            color: #2d3436;
            padding: 8px 0;
        }

        .chat-input::placeholder {
            color: #adb5bd;
        }

        .send-button {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            border-radius: 50%;
            width: 35px;
            height: 35px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-left: 10px;
        }

        .send-button:hover {
            transform: scale(1.1);
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
        }

        .input-hints {
            margin-top: 8px;
            text-align: center;
        }

        .input-hints small {
            color: #636e72;
            font-size: 0.75rem;
        }

        /* Typing indicator */
        .typing-indicator {
            display: flex;
            align-items: center;
            gap: 5px;
            color: #636e72;
            font-size: 0.8rem;
            font-style: italic;
        }

        .typing-dots {
            display: flex;
            gap: 2px;
        }

        .typing-dots span {
            width: 4px;
            height: 4px;
            background: #636e72;
            border-radius: 50%;
            animation: typingDot 1.4s infinite;
        }

        .typing-dots span:nth-child(2) {
            animation-delay: 0.2s;
        }

        .typing-dots span:nth-child(3) {
            animation-delay: 0.4s;
        }

        @keyframes typingDot {
            0%, 60%, 100% { transform: translateY(0); }
            30% { transform: translateY(-10px); }
        }

        /* Responsive Design */
        @media (max-width: 768px) {
            .weather-features-grid {
                grid-template-columns: 1fr;
            }
            
            .visualization-grid {
                grid-template-columns: 1fr;
            }
            
            .controls-grid {
                grid-template-columns: 1fr;
            }
            
            .checkbox-group {
                grid-template-columns: 1fr;
            }
            
            .footer-actions {
                flex-direction: column;
            }
        }

        /* Floating AI Assistant Button */
        .ai-fab {
            position: fixed;
            right: 24px;
            bottom: 24px;
            z-index: 1500;
            width: 56px;
            height: 56px;
            border-radius: 50%;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            box-shadow: 0 10px 24px rgba(0,0,0,0.18);
            cursor: pointer;
            transition: transform .15s ease, box-shadow .15s ease;
        }

        .ai-fab:hover {
            transform: translateY(-2px);
            box-shadow: 0 14px 28px rgba(0,0,0,0.22);
        }

        .ai-fab i { font-size: 20px; }

        .logged-user-info .user-name { max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .logged-user-info .btn { text-decoration: none; }
        .auth-buttons .btn { text-decoration: none; }
        @media (max-width: 900px) {
            .user-details { display: none; }
            .user-profile-btn span, .user-logout-btn span { display: none; }
        }


        .logged-user-info {
            gap: 10px;
        }

        .user-profile-btn,
        .user-logout-btn {
            padding: 9px 14px;
            border-radius: 18px;
            white-space: nowrap;
        }

        .theme-control-item {
            justify-content: space-between;
            cursor: default !important;
        }

        .theme-control-item:hover {
            transform: none !important;
        }

        .control-theme-toggle {
            left: 0 !important;
            margin-left: auto;
            padding: 3px;
            transform: none;
            transform-origin: right center;
        }

        .control-theme-toggle button {
            width: 32px;
            height: 32px;
            font-size: 15px;
        }

        .control-theme-toggle .toggle-bg {
            width: 32px;
            height: 32px;
            top: 3px;
            left: 3px;
        }

        .control-theme-toggle.dark-active .toggle-bg {
            transform: translateX(34px);
        }
    </style>
</head>
<body>
    <script>window.SKYCAST_USER_ID = <%- JSON.stringify(typeof userId !== 'undefined' && userId ? String(userId) : null) %>;
    window.SKYCAST_SERVER_USER = <%- JSON.stringify(typeof user !== 'undefined' && user ? String(user) : null) %>;</script>
    <!-- Loading Overlay -->
    <div class="loading-overlay" id="loadingOverlay">
        <div class="loading-spinner"></div>
    </div>

    <!-- Floating Map Controls Button -->
    <button class="controls-fab" aria-label="Toggle Map Controls" onclick="toggleControlPanel(event)">
        <i class="fas fa-layer-group"></i>
    </button>

    <!-- Enhanced Header with Search and Auth -->
    <header class="header fade-in">
        <div class="logo-section">
            <div class="logo">
                <i class="fas fa-cloud-sun"></i>
                <span>SkyCast</span>
            </div>
            <div class="welcome-text">
                Interactive Map Dashboard
            </div>
        </div>
        
        <!-- Search Bar -->
        <div class="search-section">
            <div class="search-container">
                <div class="search-input-wrapper">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text" id="mapSearch" class="search-input" placeholder="Search locations..." autocomplete="off">
                    <div class="search-results" id="searchResults"></div>
                </div>
            </div>
        </div>

        <div class="header-tools d-flex align-items-center gap-2 flex-shrink-0">
          <button type="button" class="btn btn-sm btn-outline-secondary" id="unitsToggleBtn" onclick="toggleUnits()" title="Toggle units">°C / mm</button>
          <button type="button" class="btn btn-sm btn-outline-secondary" onclick="runOnboardingTour()" title="Help tour"><i class="fas fa-question-circle"></i></button>
          <button type="button" class="btn btn-sm btn-outline-primary" onclick="shareWeatherView()" title="Copy share link"><i class="fas fa-share-alt"></i></button>
        </div>
        
        <!-- User Section -->
        <div class="user-section" id="userSection">
            <% if (user) { %>
                <div class="user-info logged-user-info">
