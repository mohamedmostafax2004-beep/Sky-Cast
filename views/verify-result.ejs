<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Email Verification - SkyCast</title>
  <link rel="stylesheet" href="/style.css">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body>
  <div class="form-container text-center">
    <div class="form-header">
      <div class="logo"><i class="fas fa-cloud-sun"></i><span>SkyCast</span></div>
      <% if (success) { %>
        <h2 class="text-success"><i class="fas fa-check-circle"></i> Success</h2>
      <% } else { %>
        <h2 class="text-danger"><i class="fas fa-times-circle"></i> Verification failed</h2>
      <% } %>
    </div>
    <p><%= message %></p>
    <% if (typeof user !== 'undefined' && user) { %>
      <a href="/dashboard" class="submit-btn" style="display:inline-block;text-decoration:none;margin-top:1rem;">Go to Dashboard</a>
    <% } else { %>
      <a href="/login" class="submit-btn" style="display:inline-block;text-decoration:none;margin-top:1rem;">Go to login</a>
    <% } %>
    <a href="/" class="back-link" style="display:block;margin-top:1rem;">Back to map</a>
  </div>
</body>
</html>
