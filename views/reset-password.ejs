<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Reset Password - SkyCast</title>
  <link rel="stylesheet" href="/style.css">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body>
  <div class="form-container">
    <div class="form-header">
      <div class="logo"><i class="fas fa-cloud-sun"></i><span>SkyCast</span></div>
      <h2>New password</h2>
    </div>
    <% if (error) { %><div class="error-message"><%= error %></div><% } %>
    <form action="/reset-password" method="post">
      <input type="hidden" name="token" value="<%= token %>">
      <div class="form-group">
        <div class="input-wrapper">
          <input type="password" name="password" required minlength="6" placeholder="New password">
        </div>
      </div>
      <div class="form-group">
        <div class="input-wrapper">
          <input type="password" name="confirmPassword" required minlength="6" placeholder="Confirm password">
        </div>
      </div>
      <button type="submit" class="submit-btn">Update password</button>
    </form>
  </div>
</body>
</html>
