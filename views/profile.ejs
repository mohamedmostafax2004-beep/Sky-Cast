<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate, private">
  <meta http-equiv="Pragma" content="no-cache">
  <meta http-equiv="Expires" content="0">
  <title>Profile - SkyCast</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <style>
    body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; padding: 2rem; }
    .profile-card { max-width: 640px; margin: 0 auto; background: #fff; border-radius: 16px; padding: 2rem; box-shadow: 0 20px 50px rgba(0,0,0,0.15); }
  </style>
</head>
<body>
  <div class="profile-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="mb-0"><i class="fas fa-user-circle text-primary"></i> Profile</h2>
      <a href="/?from=profile" class="btn btn-outline-primary btn-sm"><i class="fas fa-map"></i> Back to Map</a>
    </div>
    <p class="text-muted">Signed in as <strong><%= user %></strong></p>
    <% if (typeof resent !== 'undefined' && resent) { %>
      <div class="alert alert-success">Verification email sent.</div>
    <% } %>
    <div id="emailVerifyBox" class="alert alert-warning" style="display:none;">
      Email not verified.
      <form action="/resend-verification" method="post" class="d-inline">
        <button type="submit" class="btn btn-sm btn-outline-dark ms-2">Resend</button>
      </form>
    </div>
    <div id="profileStats" class="alert alert-info">Loading stats…</div>
    <form id="prefsForm">
      <h5 class="mt-4">Preferences</h5>
      <div class="mb-3">
        <label class="form-label">Units</label>
        <select class="form-select" id="prefUnits">
          <option value="metric">Metric (°C, mm)</option>
          <option value="imperial">Imperial (°F, in)</option>
        </select>
      </div>
      <div class="row g-2 mb-3">
        <div class="col-md-4">
          <label class="form-label">Default latitude</label>
          <input type="number" step="any" class="form-control" id="prefLat">
        </div>
        <div class="col-md-4">
          <label class="form-label">Default longitude</label>
          <input type="number" step="any" class="form-control" id="prefLng">
        </div>
        <div class="col-md-4">
          <label class="form-label">Default zoom</label>
          <input type="number" min="1" max="18" class="form-control" id="prefZoom">
        </div>
      </div>
      <h6>Weather alert thresholds</h6>
      <div class="form-check mb-2">
        <input class="form-check-input" type="checkbox" id="prefAlerts" checked>
        <label class="form-check-label" for="prefAlerts">Enable in-app weather alerts</label>
      </div>
      <div class="row g-2 mb-3">
        <div class="col-4"><label class="form-label">High temp °C</label><input type="number" class="form-control" id="prefTempHigh" value="38"></div>
        <div class="col-4"><label class="form-label">Low temp °C</label><input type="number" class="form-control" id="prefTempLow" value="5"></div>
        <div class="col-4"><label class="form-label">Rain mm/day</label><input type="number" class="form-control" id="prefPrecip" value="20"></div>
      </div>
      <button type="submit" class="btn btn-primary w-100"><i class="fas fa-save"></i> Save Preferences</button>
    </form>
    <div id="saveMsg" class="mt-3"></div>
  </div>
  <script>
    async function loadProfile() {
      try {
        const res = await fetch('/api/profile');
        const data = await res.json();
        if (!res.ok) throw new Error(data.error);
        const p = data.user.preferences || {};
        document.getElementById('profileStats').innerHTML =
          `<strong>${data.stats.locationCount}</strong> saved locations · <strong>${data.stats.markerCount}</strong> cloud markers`;
        if (!data.user.emailVerified) {
          document.getElementById('emailVerifyBox').style.display = 'block';
        }
        document.getElementById('prefUnits').value = p.units || 'metric';
        document.getElementById('prefLat').value = p.defaultLat ?? 31.2653;
        document.getElementById('prefLng').value = p.defaultLng ?? 32.3019;
        document.getElementById('prefZoom').value = p.defaultZoom ?? 13;
        document.getElementById('prefAlerts').checked = p.weatherAlerts !== false;
        document.getElementById('prefTempHigh').value = p.tempAlertHigh ?? 38;
        document.getElementById('prefTempLow').value = p.tempAlertLow ?? 5;
        document.getElementById('prefPrecip').value = p.precipAlertMm ?? 20;
      } catch (e) {
        document.getElementById('profileStats').className = 'alert alert-danger';
        document.getElementById('profileStats').textContent = e.message;
      }
    }
    document.getElementById('prefsForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const body = {
        units: document.getElementById('prefUnits').value,
        defaultLat: parseFloat(document.getElementById('prefLat').value),
        defaultLng: parseFloat(document.getElementById('prefLng').value),
        defaultZoom: parseInt(document.getElementById('prefZoom').value, 10),
        weatherAlerts: document.getElementById('prefAlerts').checked,
        tempAlertHigh: parseFloat(document.getElementById('prefTempHigh').value),
        tempAlertLow: parseFloat(document.getElementById('prefTempLow').value),
        precipAlertMm: parseFloat(document.getElementById('prefPrecip').value),
      };
      const res = await fetch('/api/profile/preferences', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const data = await res.json();
      const msg = document.getElementById('saveMsg');
      if (res.ok) {
        msg.innerHTML = '<div class="alert alert-success">Preferences saved.</div>';
        localStorage.setItem('skycast_prefs', JSON.stringify({ units: body.units, weatherAlerts: body.weatherAlerts, tempAlertHigh: body.tempAlertHigh, tempAlertLow: body.tempAlertLow, precipAlertMm: body.precipAlertMm }));
      } else {
        msg.innerHTML = `<div class="alert alert-danger">${data.error || 'Save failed'}</div>`;
      }
    });
    loadProfile();
  </script>
</body>
</html>
