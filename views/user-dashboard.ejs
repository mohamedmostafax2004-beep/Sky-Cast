<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>User Dashboard - SkyCast</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <style>
    * { box-sizing: border-box; }
    body {
      min-height: 100vh;
      margin: 0;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background:
        radial-gradient(circle at top left, rgba(122, 92, 255, .26), transparent 30%),
        radial-gradient(circle at bottom right, rgba(0, 190, 255, .18), transparent 35%),
        linear-gradient(135deg, #f4f7fb 0%, #edf1f7 100%);
      color: #1f2937;
    }
    .topbar {
      height: 76px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 48px;
      background: rgba(255,255,255,.88);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(148,163,184,.28);
      box-shadow: 0 10px 30px rgba(15,23,42,.06);
    }
    .brand { display:flex; align-items:center; gap:12px; font-weight:800; color:#4f46e5; font-size:24px; }
    .brand i { font-size:28px; }
    .user-pill { display:flex; align-items:center; gap:12px; padding:8px 14px; border-radius:999px; background:#f8fafc; border:1px solid #e2e8f0; }
    .avatar { width:42px; height:42px; border-radius:50%; display:grid; place-items:center; color:white; background:linear-gradient(135deg,#4f46e5,#7c3aed); font-weight:800; }
    .user-name { font-weight:800; line-height:1.1; }
    .user-email { color:#64748b; font-size:13px; }
    .page { max-width:1100px; margin:42px auto; padding:0 22px; }
    .hero {
      background: rgba(255,255,255,.92);
      border:1px solid rgba(226,232,240,.9);
      border-radius:28px;
      padding:36px;
      box-shadow:0 25px 60px rgba(15,23,42,.10);
      overflow:hidden;
      position:relative;
    }
    .hero:after { content:""; position:absolute; width:260px; height:260px; border-radius:50%; background:linear-gradient(135deg,rgba(79,70,229,.16),rgba(14,165,233,.12)); right:-70px; top:-80px; }
    .hero-content { position:relative; z-index:1; }
    .welcome-title { font-size:38px; font-weight:900; margin:0 0 10px; color:#111827; }
    .welcome-title span { color:#4f46e5; }
    .lead-text { font-size:17px; color:#64748b; margin-bottom:28px; max-width:700px; }
    .success-box { border-radius:16px; padding:14px 18px; margin-bottom:22px; background:#ecfdf5; color:#065f46; border:1px solid #a7f3d0; font-weight:700; }
    .actions { display:flex; flex-wrap:wrap; gap:14px; }
    .action-btn { text-decoration:none; border:0; border-radius:16px; padding:14px 20px; font-weight:800; display:inline-flex; align-items:center; gap:10px; transition:.2s; }
    .primary { color:#fff; background:linear-gradient(135deg,#4f46e5,#7c3aed); box-shadow:0 12px 28px rgba(79,70,229,.25); }
    .secondary { color:#4f46e5; background:#eef2ff; border:1px solid #c7d2fe; }
    .danger { color:#dc2626; background:#fff1f2; border:1px solid #fecdd3; }
    .action-btn:hover { transform:translateY(-2px); filter:brightness(.98); }
    .cards { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:18px; margin-top:24px; }
    .card-box { background:#fff; border:1px solid #e2e8f0; border-radius:22px; padding:24px; box-shadow:0 14px 35px rgba(15,23,42,.06); }
    .card-icon { width:48px; height:48px; border-radius:16px; display:grid; place-items:center; background:#eef2ff; color:#4f46e5; font-size:22px; margin-bottom:14px; }
    .card-title { font-weight:900; margin-bottom:6px; }
    .card-text { color:#64748b; margin:0; font-size:14px; }
    .stats-row { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:16px; margin-top:24px; }
    .stat { background:#0f172a; color:white; border-radius:20px; padding:20px; }
    .stat strong { display:block; font-size:30px; line-height:1; margin-bottom:6px; }
    .stat span { color:#cbd5e1; font-size:14px; }
    @media (max-width: 850px) {
      .topbar { padding:0 18px; height:auto; min-height:76px; flex-wrap:wrap; gap:10px; }
      .page { margin:24px auto; }
      .cards, .stats-row { grid-template-columns:1fr; }
      .welcome-title { font-size:30px; }
      .user-email { display:none; }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="brand"><i class="fas fa-cloud-sun"></i> SkyCast</div>
    <div class="user-pill">
      <div class="avatar"><%= user ? user.charAt(0).toUpperCase() : 'U' %></div>
      <div>
        <div class="user-name"><%= user %></div>
        <div class="user-email"><%= email || 'SkyCast user' %></div>
      </div>
    </div>
  </header>

  <main class="page">
    <section class="hero">
      <div class="hero-content">
        <% if (created) { %>
          <div class="success-box"><i class="fas fa-check-circle"></i> Account created successfully. You are signed in now.</div>
        <% } %>
        <h1 class="welcome-title">Welcome, <span><%= user %></span></h1>
        <p class="lead-text">This is your SkyCast account dashboard. From here you can open the weather map, manage your profile, save locations, and export weather reports.</p>
        <div class="actions">
          <a href="/" class="action-btn primary"><i class="fas fa-map-location-dot"></i> Open Weather Map</a>
          <a href="/profile" class="action-btn secondary"><i class="fas fa-user-gear"></i> Profile Settings</a>
          <a href="/logout" class="action-btn danger"><i class="fas fa-right-from-bracket"></i> Logout</a>
        </div>
      </div>
    </section>

    <section class="stats-row">
      <div class="stat"><strong id="savedLocations">--</strong><span>Saved locations</span></div>
      <div class="stat"><strong id="savedMarkers">--</strong><span>Map markers</span></div>
      <div class="stat"><strong><%= dbConnected ? 'ON' : 'OFF' %></strong><span>Database status</span></div>
    </section>

    <section class="cards">
      <div class="card-box">
        <div class="card-icon"><i class="fas fa-cloud-sun-rain"></i></div>
        <div class="card-title">Forecast Dashboard</div>
        <p class="card-text">Search any location, select a date range, and view expected weather conditions using charts.</p>
      </div>
      <div class="card-box">
        <div class="card-icon"><i class="fas fa-location-dot"></i></div>
        <div class="card-title">Saved Locations</div>
        <p class="card-text">Save important locations and return to them quickly from your personal account.</p>
      </div>
      <div class="card-box">
        <div class="card-icon"><i class="fas fa-file-pdf"></i></div>
        <div class="card-title">PDF Reports</div>
        <p class="card-text">Export weather results and comparisons as PDF reports for documentation and analysis.</p>
      </div>
    </section>
  </main>

  <script>
    async function loadStats() {
      try {
        const res = await fetch('/api/profile');
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed');
        document.getElementById('savedLocations').textContent = data.stats.locationCount ?? 0;
        document.getElementById('savedMarkers').textContent = data.stats.markerCount ?? 0;
      } catch (err) {
        document.getElementById('savedLocations').textContent = '0';
        document.getElementById('savedMarkers').textContent = '0';
      }
    }
    loadStats();
  </script>
</body>
</html>
