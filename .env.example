NODE_ENV=development
PORT=5001
APP_URL=http://localhost:5001

SESSION_SECRET=change_this_to_a_long_random_string

# Required for accounts, saved locations, markers
# Local MongoDB (install MongoDB Server), Atlas, or JSON fallback in dev:
MONGODB_URI=mongodb://127.0.0.1:27017/skycast
USE_EMBEDDED_MONGO=false
# Atlas (must be a valid cluster — get URI from cloud.mongodb.com):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/skycast?retryWrites=true&w=majority

# Optional map tiles
JAWG_ACCESS_TOKEN=

# Email (verification + password reset). If unset, links print to server console.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=SkyCast <noreply@yourdomain.com>

# Set true to block login until email is verified
REQUIRE_EMAIL_VERIFICATION=false

# OpenAI (or compatible API e.g. Ollama with OPENAI_BASE_URL)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
